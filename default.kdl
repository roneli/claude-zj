layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm" {
                format_left   "{mode} {pipe_status}"
                format_center ""
                format_right  "{notifications}"
                format_space  ""

                border_enabled  "false"
                border_char     "─"
                border_format   "#[fg=#6C7086]{char}"
                border_position "top"

                hide_frame_for_single_pane "true"

                mode_normal  "#[bg=blue] "
                mode_tmux    "#[bg=#ffc387] "

                notifications_format_unread "#[fg=#89B4FA,bg=#181825] {message} "
                notifications_format_no_notifications ""
                notifications_show_interval "10"

                // Claude activity status
                pipe_status_format "#[fg=#6C7086]{output}"
                pipe_status_rendermode "dynamic"
            }
        }
        pane size=1 borderless=true {
            plugin location="status-bar"
        }
    }
}
